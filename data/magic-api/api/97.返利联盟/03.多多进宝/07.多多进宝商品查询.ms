import pdd;    //导入tbk模块

var params =  {
    apiMethodName:"pdd.ddk.goods.search"
    };
if(body!=null){
    params.putAll(body);
}
var response = pdd.execute(params);
if(response.errorResponse!=null){
    exit 500,response.errorResponse.errorMsg+"."+response.errorResponse.subMsg;
}
return response;