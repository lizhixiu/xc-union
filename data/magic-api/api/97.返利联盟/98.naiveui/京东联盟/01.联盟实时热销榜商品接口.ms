import jd;    //导入jd模块

var params =  {
    apiMethodName:"jd.union.open.goods.rank.query"
    };
if(body!=null){
    params.putAll(body);
}

params.RankGoodsReq.pageIndex= body.current;
params.RankGoodsReq.pageSize = body.size;

var response = jd.execute(params);
if(response.queryResult!=null && response.queryResult.code!=200 ) {
    exit 500,response.queryResult.message;
}
return {list:response.queryResult.data,total:response.queryResult.totalCount};
